# Node (if any tooling added later)
node_modules/

# Python bytecode caches from dev-tools/* debug sessions
__pycache__/
*.pyc

# TUNE-0090: framework repo MUST NOT contain documentation/ — that is a consumer-side artefact.
# Consumer projects write task archives to documentation/archive/ per CLAUDE.md template.
# Framework workflow state lives in Projects/Datarim/datarim/; security/insights archives in ~/arcanada/documentation/.
documentation/

# TUNE-0164: dr-orchestrate plugin operator config (mode-0600 secrets via secrets_backend.sh).
# Template ships at plugins/dr-orchestrate/user-config.template.yaml.
plugins/dr-orchestrate/user-config.yaml

# TUNE-0254: stage-snapshot ephemeral state — overwritten per /dr-* run.
# Snapshot at datarim/snapshots/{TASK-ID}.snapshot.md, gitignored; /dr-archive
# Step 0.95 moves the final snapshot to documentation/archive/<subdir>/snapshots/.
datarim/snapshots/

# TUNE-0268 Phase 2: backlog.md.lock — flock guard для datarim backlog add.
*.lock

# TUNE-0296: Codex CLI auto-recreates bundled skills under skills/.system/ when
# ~/.codex/skills → datarim/skills/ symlink is in place (--with-codex install
# path). These are runtime artefacts owned by Codex CLI, not Datarim source.
# Permanent integration design tracked in backlog (Source: TUNE-0296).
skills/.system/
